{
    "mcpServers": {
        "mcp-language-server": {
            "command": ".mcp/mcp-language-server",
            "args": [
                "-workspace",
                "/home/angalato/workspace/mcp_dap",
                "-lsp",
                "rust:rust-analyzer"
            ]
        },
        "mcp-dap-rs": {
            "command": "target/release/mcp-dap-rs"
        }
    },
    "general": {
        "plan": {
            "modelRouting": true
        }
    },
    "modelConfigs": {
        "overrides": [
            {
                "match": { "overrideScope": "codebaseInvestigator" },
                "modelConfig": {
                    "generateContentConfig": {
                        "thinkingConfig": { "includeThinking": true, "thinkingBudget": 16384 }
                    }
                }
            },
            {
                "match": { "overrideScope": "chat" },
                "modelConfig": {
                    "generateContentConfig": {
                        "thinkingConfig": { "includeThinking": true, "thinkingBudget": 8192 }
                    }
                }
            }
        ]
    },
    "experimental": {
        "toolOutputMasking": {
            "enabled": true
        }
    }
}
